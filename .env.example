# ============================================================
# FlowCRM — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Convex (required) ─────────────────────────────────────────
# Get the URL from: Convex Dashboard → your project → Settings → URL & Deploy Key
# All team members MUST point to the SAME deployment URL, not localhost.
VITE_CONVEX_URL=https://your-project-slug.convex.cloud

# Only needed when running `npx convex dev` or `npx convex deploy` locally
# Format: team-slug:project-slug
CONVEX_DEPLOYMENT=your-team:your-project

# ── Supabase (legacy — no longer used) ───────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
