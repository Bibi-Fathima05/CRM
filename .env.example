# ============================================================
# FlowCRM — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Convex (required) ─────────────────────────────────────────
# SETUP (do this once as team lead):
#   1. npx convex login
#   2. npx convex dev --new   (creates a shared project)
#   3. Copy the deployment URL shown and share it with all teammates
#   4. Everyone sets VITE_CONVEX_URL below to that same URL
#
# All team members MUST use the same URL — never use http://localhost
VITE_CONVEX_URL=https://your-project-slug.convex.cloud

# ── Supabase (legacy — no longer used) ───────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
